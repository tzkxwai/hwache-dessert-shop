<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Pacifico&display=swap" rel="stylesheet" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/hwache.styles.css" asp-append-version="true" />
</head>
<body class="hwache-body">
    @{
        var hwHome = Url.Action("Index", "Home") ?? "/";
    }
    <header class="hwache-header sticky-top">
        <nav class="navbar navbar-expand-lg">
            <div class="container hwache-container">
                <a class="navbar-brand hwache-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/images/hwache-logo.png" width="180" height="180" class="hwache-brand__logo" alt="@L["Brand"]" />
                </a>
                <button class="navbar-toggler hwache-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#hwNav"
                        aria-controls="hwNav" aria-expanded="false" aria-label="Menu">
                    <span class="navbar-toggler-icon hwache-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="hwNav">
                    <ul class="navbar-nav mx-auto gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link hwache-nav-link" href="@($"{hwHome}#menu")">@L["NavMenu"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link hwache-nav-link" href="@($"{hwHome}#how")">@L["NavHow"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link hwache-nav-link" asp-controller="Home" asp-action="Privacy">@L["NavAbout"]</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-2 hwache-nav-actions">
                        <button type="button" class="hwache-cart-btn" id="hwCartToggle" data-bs-toggle="offcanvas" data-bs-target="#hwCartOffcanvas" aria-controls="hwCartOffcanvas" aria-label="@L["CartOpenAria"]">
                            <span class="hwache-cart-btn__icon" aria-hidden="true">🛒</span>
                            <span class="hwache-cart-btn__badge" id="hwCartBadge" hidden>0</span>
                        </button>
                        <div class="d-flex align-items-center gap-2 hwache-lang">
                        @{
                            var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
                        }
                        <a class="hwache-lang-btn @(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ru" ? "active" : null)"
                           asp-controller="Home" asp-action="SetLanguage" asp-route-culture="ru" asp-route-returnUrl="@returnUrl">@L["LangRu"]</a>
                        <span class="hwache-lang-sep" aria-hidden="true">|</span>
                        <a class="hwache-lang-btn @(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "uk" ? "active" : null)"
                           asp-controller="Home" asp-action="SetLanguage" asp-route-culture="uk" asp-route-returnUrl="@returnUrl">@L["LangUk"]</a>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div id="hw-cart-i18n" class="d-none" aria-hidden="true"
         data-title="@L["CartTitle"]"
         data-empty="@L["CartEmpty"]"
         data-total="@L["CartTotal"]"
         data-clear="@L["CartClear"]"
         data-remove="@L["CartRemoveLine"]"
         data-currency="@L["CartCurrency"]"></div>

    <div class="offcanvas offcanvas-end hwache-cart-panel" tabindex="-1" id="hwCartOffcanvas" aria-labelledby="hwCartOffcanvasLabel">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title fw-bold" id="hwCartOffcanvasLabel">@L["CartTitle"]</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="@L["CartClose"]"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column">
            <p class="text-muted small mb-3" id="hwCartEmpty">@L["CartEmpty"]</p>
            <ul class="list-unstyled flex-grow-1 mb-0" id="hwCartList"></ul>
            <div class="hwache-cart-footer mt-4 pt-3 border-top" id="hwCartFooter" hidden>
                <div class="d-flex justify-content-between align-items-center fw-bold mb-3">
                    <span>@L["CartTotal"]</span>
                    <span id="hwCartTotal">0 @L["CartCurrency"]</span>
                </div>
                <button type="button" class="btn hwache-btn-outline w-100" id="hwCartClear">@L["CartClear"]</button>
            </div>
        </div>
    </div>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="hwache-footer">
        <div class="container hwache-container py-4">
            <p class="hwache-footer__tag mb-1">@L["FooterTagline"]</p>
            <p class="hwache-footer__copy mb-0">@L["FooterCopy", DateTime.Now.Year]</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
