@{
    ViewData["Title"] = L["TitleAbout"].Value;
    var home = Url.Action("Index", "Home") ?? "/";
}

<div class="container hwache-container hwache-page py-5 hwache-section--muted">
    <h1 class="hwache-page__title mb-3">@L["AboutTitle"]</h1>
    <p class="lead hwache-page__lead">@L["AboutLead"]</p>
    <p>@L["AboutP1"]</p>
    <p>@L["AboutP2"]</p>
    <p class="mt-4 mb-0">
        <a class="btn hwache-btn-primary" href="@($"{home}#menu")">@L["BackHome"]</a>
    </p>
</div>
