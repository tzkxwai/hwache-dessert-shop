@{
    ViewData["Title"] = L["TitleHome"].Value;
    var home = Url.Action("Index", "Home") ?? "/";
}

<section class="hwache-hero">
    <div class="container hwache-container">
        <div class="row align-items-center g-4 py-5">
            <div class="col-lg-6">
                <p class="hwache-hero__decor mb-1 d-flex align-items-center gap-2" aria-hidden="true">
                    <span class="hwache-spark hwache-spark--pink">✦</span>
                    <span class="hwache-spark hwache-spark--lime">✧</span>
                    <span class="hwache-spark hwache-spark--pink">✦</span>
                </p>
                <p class="hwache-badge mb-3">@L["HeroBadge"]</p>
                <h1 class="hwache-hero__title">@L["HeroTitle"]</h1>
                <p class="hwache-hero__lead">@L["HeroSubtitle"]</p>
                <p class="hwache-hero__note small mb-4">@L["HeroNote"]</p>
                <a class="btn hwache-btn-primary btn-lg" href="@($"{home}#menu")">@L["HeroCta"]</a>
            </div>
            <div class="col-lg-6">
                <div class="hwache-hero-sticker">
                    <span class="hwache-hero-sticker__spark hwache-hero-sticker__spark--1 hwache-spark hwache-spark--lime" aria-hidden="true">✦</span>
                    <span class="hwache-hero-sticker__spark hwache-hero-sticker__spark--2 hwache-spark hwache-spark--pink" aria-hidden="true">✧</span>
                    <span class="hwache-hero-sticker__spark hwache-hero-sticker__spark--3 hwache-spark hwache-spark--pink" aria-hidden="true">✦</span>
                    <div class="hwache-hero-sticker__frame">
                        <img src="~/images/hwache-logo.png" alt="@L["Brand"]" width="400" height="400" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="menu" class="hwache-section">
    <div class="container hwache-container">
        <h2 class="hwache-section__title">@L["SectionCategories"]</h2>
        <div class="row g-3 g-md-4 mb-4">
            <div class="col-6 col-md-3">
                <a class="hwache-cat hwache-cat--link" href="@($"{home}#menu-firm-drinks")">🥤<span>@L["CatPizza"]</span></a>
            </div>
            <div class="col-6 col-md-3">
                <a class="hwache-cat hwache-cat--link" href="@($"{home}#menu-desserts-snacks")">🍰<span>@L["CatSushi"]</span></a>
            </div>
            <div class="col-6 col-md-3">
                <a class="hwache-cat hwache-cat--link" href="@($"{home}#menu-specials")">🥡<span>@L["CatBurgers"]</span></a>
            </div>
            <div class="col-6 col-md-3">
                <a class="hwache-cat hwache-cat--link" href="@($"{home}#menu-hwache")">🍉<span>@L["CatDesserts"]</span></a>
            </div>
        </div>
        <p class="text-center small hwache-cat-hint mb-5">@L["CatJumpHint"]</p>

        <h2 id="popular" class="hwache-section__title">@L["SectionPopular"]</h2>
        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                <article class="hwache-dish">
                    <div class="hwache-dish__emoji" aria-hidden="true">🍰</div>
                    <h3 class="hwache-dish__name">@L["Dish1Name"]</h3>
                    <p class="hwache-dish__desc">@L["Dish1Desc"]</p>
                    <div class="hwache-dish__row">
                        <span class="hwache-dish__price">@L["PriceFrom", 189]</span>
                        <button type="button" class="btn btn-sm hwache-btn-outline hwache-add-cart" data-product-id="popular-1" data-product-name="@L["Dish1Name"]" data-product-price="189">@L["AddToCart"]</button>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="hwache-dish">
                    <div class="hwache-dish__emoji" aria-hidden="true">🥭</div>
                    <h3 class="hwache-dish__name">@L["Dish2Name"]</h3>
                    <p class="hwache-dish__desc">@L["Dish2Desc"]</p>
                    <div class="hwache-dish__row">
                        <span class="hwache-dish__price">@L["PriceFrom", 95]</span>
                        <button type="button" class="btn btn-sm hwache-btn-outline hwache-add-cart" data-product-id="popular-2" data-product-name="@L["Dish2Name"]" data-product-price="95">@L["AddToCart"]</button>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="hwache-dish">
                    <div class="hwache-dish__emoji" aria-hidden="true">🍡</div>
                    <h3 class="hwache-dish__name">@L["Dish3Name"]</h3>
                    <p class="hwache-dish__desc">@L["Dish3Desc"]</p>
                    <div class="hwache-dish__row">
                        <span class="hwache-dish__price">@L["PriceFrom", 220]</span>
                        <button type="button" class="btn btn-sm hwache-btn-outline hwache-add-cart" data-product-id="popular-3" data-product-name="@L["Dish3Name"]" data-product-price="220">@L["AddToCart"]</button>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="hwache-dish">
                    <div class="hwache-dish__emoji" aria-hidden="true">🍨</div>
                    <h3 class="hwache-dish__name">@L["Dish4Name"]</h3>
                    <p class="hwache-dish__desc">@L["Dish4Desc"]</p>
                    <div class="hwache-dish__row">
                        <span class="hwache-dish__price">@L["PriceFrom", 129]</span>
                        <button type="button" class="btn btn-sm hwache-btn-outline hwache-add-cart" data-product-id="popular-4" data-product-name="@L["Dish4Name"]" data-product-price="129">@L["AddToCart"]</button>
                    </div>
                </article>
            </div>
        </div>

        @await Html.PartialAsync("_MenuCatalog")
    </div>
</section>

<section id="how" class="hwache-section hwache-section--muted">
    <div class="container hwache-container">
        <h2 class="hwache-section__title">@L["SectionHow"]</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="hwache-step">
                    <span class="hwache-step__num">1</span>
                    <h3 class="hwache-step__title">@L["Step1Title"]</h3>
                    <p class="hwache-step__text mb-0">@L["Step1Desc"]</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hwache-step">
                    <span class="hwache-step__num">2</span>
                    <h3 class="hwache-step__title">@L["Step2Title"]</h3>
                    <p class="hwache-step__text mb-0">@L["Step2Desc"]</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hwache-step">
                    <span class="hwache-step__num">3</span>
                    <h3 class="hwache-step__title">@L["Step3Title"]</h3>
                    <p class="hwache-step__text mb-0">@L["Step3Desc"]</p>
                </div>
            </div>
        </div>
    </div>
</section>
